{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Harness Eval Result",
  "description": "하네스 빌더 도구 평가 결과 스키마",
  "type": "object",
  "properties": {
    "overall_pass": {
      "type": "boolean",
      "description": "전체 평가 통과 여부"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "점수 (0-100)"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "체크 ID" },
          "pass": { "type": "boolean", "description": "통과 여부" },
          "notes": { "type": "string", "description": "비고" }
        },
        "required": ["id", "pass", "notes"]
      }
    },
    "token_usage": {
      "type": "object",
      "properties": {
        "input": { "type": "integer" },
        "output": { "type": "integer" }
      }
    },
    "duration_ms": {
      "type": "number",
      "description": "실행 시간 (ms)"
    }
  },
  "required": ["overall_pass", "score", "checks"]
}
