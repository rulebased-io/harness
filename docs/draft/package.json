{
  "name": "harness-builder-mcp",
  "version": "1.0.0",
  "description": "MCP Server for building and managing test harnesses in Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
