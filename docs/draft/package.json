    "mcp:inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "mcp": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  }
}
