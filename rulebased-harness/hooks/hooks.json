{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/resolve-plugin-path.sh",
            "statusMessage": "Resolving harness plugin path..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-version-bump.sh",
            "statusMessage": "Checking plugin version..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-version-bump.sh",
            "statusMessage": "Checking plugin version..."
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/eval-on-stop.sh",
            "async": true,
            "statusMessage": "Evaluating session harness compliance..."
          }
        ]
      }
    ]
  }
}
